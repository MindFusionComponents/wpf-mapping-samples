<Window
	x:Class="MindFusion.Mapping.Wpf.Samples.CS.Markers.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:map="http://mindfusion.eu/mapping/wpf"
	mc:Ignorable="d"
	Title="MindFusion.Mapping for WPF Sample: Markers"
	Width="900" Height="700"
	WindowState="Maximized" Icon="/Markers;component/App.ico">

	<Grid x:Name="LayoutRoot">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>
		<ScrollViewer HorizontalScrollBarVisibility="Auto" >
			<map:MapView Margin="0" Name="mapView">
			</map:MapView>
		</ScrollViewer>
		<TextBlock TextWrapping="Wrap" Margin="5" Grid.Row="1" Text="This example shows how to add custom markers to the map using a decoration layer. DecorationLayers can contain DecorationImage and DecorationBubble objects associated with given latitude and longitude.
You can zoom down using the mouse wheel and pan the map by dragging it with left mouse button." />
	</Grid>
</Window>