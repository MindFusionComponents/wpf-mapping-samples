<Window
	x:Class="MindFusion.Mapping.Wpf.Samples.CS.Palette.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:map="http://mindfusion.eu/mapping/wpf"
	mc:Ignorable="d"
	Title="MindFusion.Mapping for WPF Sample: Palette"
	Width="900" Height="700"
	WindowState="Maximized" Icon="/Palette;component/App.ico">
	
	<Grid x:Name="LayoutRoot">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="200" />
			</Grid.ColumnDefinitions>

			<ScrollViewer x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" >
				<map:MapView Name="mapView" AllowDrop="True" DragOver="mapView_DragOver" Drop="mapView_Drop" />
			</ScrollViewer>

			<ListBox Name="lbImages" Grid.Column="1" Background="White" />

		</Grid>
		<TextBlock Name="label" Grid.Row="1" Text="This sample shows how to implement drag and drop from a list of images to a map view. Click an image on the right and drag it to a land area on the left to create a new map decoration.
You can zoom down using the mouse wheel and pan the map by dragging it with left mouse button." TextWrapping="Wrap" />
	</Grid>
</Window>