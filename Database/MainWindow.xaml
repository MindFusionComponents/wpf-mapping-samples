<Window
	x:Class="MindFusion.Mapping.Wpf.Samples.CS.Database.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:map="http://mindfusion.eu/mapping/wpf"
	Title="MindFusion.Mapping for WPF Sample: Database"
	Width="900" Height="700"
	WindowState="Maximized" Icon="/Database;component/App.ico">

	<Grid x:Name="LayoutRoot" Background="White">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="40"/>
		</Grid.RowDefinitions>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="280"/>
			</Grid.ColumnDefinitions>

			<ScrollViewer HorizontalScrollBarVisibility="Auto">
				<!-- the map is shown here -->
				<map:MapView
					x:Name="mapView"
					MapElementClick="mapView_MapElementClick">

					<!-- add one map layer -->
					<map:MapLayer
						LineColor="Transparent"
						AutoAssignColors="true">
					</map:MapLayer>

				</map:MapView>
			</ScrollViewer>

			<!-- display database fields for the selected map region -->
			<Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1">
				<StackPanel Name="stPnlProperties">
				</StackPanel>
			</Border>
		</Grid>
		<TextBlock Grid.Row="1" Text="This sample shows data from the dbf database associated with a shapefile. Left-click on a country to show its data row in the property grid on the right. 
Double-click to display the Wikipedia article for the country. You can zoom down using the mouse wheel and pan the map by dragging it with left mouse button." TextWrapping="Wrap" />
	</Grid>
</Window>