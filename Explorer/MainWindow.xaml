<Window
	x:Class="MindFusion.Mapping.Wpf.Samples.CS.Explorer.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:map="http://mindfusion.eu/mapping/wpf"
	Title="MindFusion.Mapping for WPF Sample: Explorer"
	Width="900" Height="700"
	WindowState="Maximized" Icon="/Explorer;component/App.ico">

	<Grid x:Name="LayoutRoot" Background="White">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="60" />
		</Grid.RowDefinitions>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="320" />
			</Grid.ColumnDefinitions>

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="300" />
				</Grid.RowDefinitions>

				<ScrollViewer HorizontalScrollBarVisibility="Auto" >

					<!-- show the selected map file -->
					<map:MapView
						Name="mapView"
						MapElementClick="mapView_MapElementClick">

						<!-- add one layer -->
						<map:MapLayer />

					</map:MapView>

				</ScrollViewer>

				<!-- display the database associated with selected map -->
				<ListView x:Name="infoGrid" Grid.Row="1" SelectionChanged="infoGrid_SelectionChanged">
					<ListView.View>
						<GridView AllowsColumnReorder="false" />
					</ListView.View>
				</ListView>
			</Grid>

			<!-- display a list of all map files -->
			<ListBox
				Grid.Column="1"
				Margin="0"
				Name="lbCountries"
				SelectionChanged="lbCountries_SelectedIndexChanged"/>
		</Grid>

		<TextBlock Margin="5" TextWrapping="Wrap" Grid.Row="1" Text="Select a map from the list to load it along with its associated database. Once the map is loaded, clicking on a database row highlights its corresponding map shape, and clicking on a map shape highlights its row.
You can zoom down using the mouse wheel and pan the map by dragging it with left mouse button." />
	</Grid>
</Window>