<Window
	x:Class="MindFusion.Mapping.Wpf.Samples.CS.Layers.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:map="http://mindfusion.eu/mapping/wpf"
	mc:Ignorable="d"
	Title="MindFusion.Mapping for WPF Sample: Layers"
	Width="900" Height="700"
	WindowState="Maximized" Icon="/Layers;component/App.ico">
	
	<Grid x:Name="LayoutRoot" Background="White">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="320" />
			</Grid.ColumnDefinitions>

			<ScrollViewer HorizontalScrollBarVisibility="Auto">
				<map:MapView Name="mapView">
				</map:MapView>
			</ScrollViewer>

			<CheckBox Grid.Column="1" Margin="10,10" Name="chBxShowLayer1" Checked="ChBxShowLayer1_Checked" Unchecked="ChBxShowLayer1_Unchecked" Content="Show Layer 1 (base map)" IsChecked="True" />
			<CheckBox Grid.Column="1" Margin="10,35" Name="chBxShowLayer2" Checked="ChBxShowLayer2_Checked" Unchecked="ChBxShowLayer2_Unchecked" Content="Show Layer 2 (urban areas)" />
			<CheckBox Grid.Column="1" Margin="10,60" Name="chBxShowLayer3" Checked="ChBxShowLayer3_Checked" Unchecked="ChBxShowLayer3_Unchecked" Content="Show Layer 3 (rivers)" />
		</Grid>
		<TextBlock Grid.Row="1" Text="This example shows how to set up several map layers. Use the checkbox controls on the right to show or hide individual layers. You can zoom down using the mouse wheel and pan the map by dragging it with left mouse button." />
	</Grid>
</Window>